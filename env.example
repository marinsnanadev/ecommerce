# URL base da API do back-end (FastAPI).
# Em desenvolvimento local, o padrão já é http://127.0.0.1:8000 (não precisa setar).
# Em produção, aponte para a URL pública da sua API.
REACT_APP_API_URL=http://127.0.0.1:8000

# Configs de dev do Create React App (hot-reload em ambientes onde o watch nativo falha,
# como Docker/WSL). Só precisa se estiver enfrentando esse problema.
# WATCHPACK_POLLING=true
# CHOKIDAR_USEPOLLING=true
