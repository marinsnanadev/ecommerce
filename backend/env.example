# Chave usada para assinar os tokens JWT de autenticação.
# Em desenvolvimento, um valor padrão inseguro já é usado automaticamente se
# essa variável não for definida — mas em produção é OBRIGATÓRIO definir
# um valor único e secreto aqui (por exemplo, gerado com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# ).
SECRET_KEY=troque-por-uma-chave-secreta-e-aleatoria

# URL(s) do front-end autorizadas a chamar esta API (CORS), separadas por
# vírgula se houver mais de uma. Em desenvolvimento já cai em
# http://localhost:3000 automaticamente se essa variável não for definida.
# Em produção, defina a URL pública real do front-end, por exemplo:
#   CORS_ORIGINS=https://meusite.com,https://www.meusite.com
CORS_ORIGINS=http://localhost:3000
